-- Exploratory Data Analysis
-- Question 1: Which products have high sales but negative profit?
SELECT
    product_name,
    SUM(sales) AS total_sales,
    SUM(profit) AS total_profit
FROM retail_data
GROUP BY product_name
HAVING SUM(profit) < 0
ORDER BY total_sales DESC;

-- Question 2: At what discount levels does profitability begin to decline?
SELECT
    discount,
    ROUND(AVG(profit),2) AS avg_profit
FROM retail_
GROUP BY discount
ORDER BY discount;

-- Question 3: What categories drive the highest profit?
SELECT
    category,
    SUM(sales) AS sales,
    SUM(profit) AS profit
FROM retail_data
GROUP BY category
ORDER BY profit DESC;

-- Question 4: Which subcategories consistently lose money?
SELECT
    sub_category,
    SUM(profit) AS profit
FROM retail_data
GROUP BY sub_category
ORDER BY profit ASC;

-- Question 5: Which customer segment is most profitable?
SELECT
    segment,
    SUM(sales) AS sales,
    SUM(profit) AS profit
FROM retail_data
GROUP BY segment;

-- Question 6: Who are the highest-value customers?
SELECT
    customer_name,
    SUM(sales) AS revenue,
    SUM(profit) AS profit
FROM retail_data
GROUP BY customer_name
ORDER BY profit DESC
LIMIT 10;

-- Question 7: How much profit is lost due to returned orders?
SELECT
    returned,
    SUM(sales) AS sales,
    SUM(profit) AS profit
FROM retail_data
GROUP BY returned;

-- Question 8: Which products have the highest return sales?
SELECT
    product_name,
    COUNT(*) AS return_count
FROM retail_data
WHERE returned = 'Yes'
GROUP BY product_name
ORDER BY return_count DESC;

-- Question 9: Does shipping performance impact profitability?
SELECT
    shipping_performance,
    SUM(profit) AS profit,
    AVG(shipping_days) AS avg_days
FROM retail_data
GROUP BY shipping_performance;

-- Question 10: Which regions are underperforming?
SELECT
    region,
    SUM(sales) AS sales,
    SUM(profit) AS profit
FROM retail_data
GROUP BY region
ORDER BY profit ASC;

